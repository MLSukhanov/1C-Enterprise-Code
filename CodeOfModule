Процедура МатрВ(матр, б, ом)
  Для i=0 по матр.ВГраница() Цикл
	Для j=0 по матр.ВГраница() Цикл
	  Если i <> j Тогда
	    матр[i][j] = ом*матр[i][j]/матр[i][i];
	    матр[i][j] = -1*матр[i][j];
	  Иначе
		Продолжить;
	  КонецЕсли;
	КонецЦикла;
	б[i] = ом*б[i]/матр[i][i];
	матр[i][i] = 0;
  КонецЦикла;
КонецПроцедуры

Процедура МатрВТау(матр, б, тау)
  Для i=0 по матр.ВГраница() Цикл
	б[i] = б[i]/(1+тау);
	Для j=0 по матр.ВГраница() Цикл
	  Если i <> j Тогда	
		  матр[i][j] = матр[i][j]/(1+тау);
	  Иначе
		  матр[i][j] = (матр[i][j]+тау)/(1+тау);
	  КонецЕсли;
    КонецЦикла;
  КонецЦикла;	
КонецПроцедуры

Функция нормаМатр(a, N)
