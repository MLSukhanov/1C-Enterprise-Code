  flag = истина;
  СортировкаХоара(maxind, 0, maxind.ВГраница(),,);
  
  Для i=0 по N-1 Цикл
	Если maxind[i] = i Тогда
	    flag = flag и истина;
    Иначе
	    flag = ложь;
	  Прервать;
	КонецЕсли;
  КонецЦикла;
Возврат flag;
КонецФункции

Процедура СортировкаХоара(arr_1D, начало, конец, б, arr_2D)
  Перем опорный;	
  Если начало < конец Тогда
	  опорный = разделение(arr_1D, начало, конец, б, arr_2D);
	  Если начало < опорный-1 Тогда
	    СортировкаХоара(arr_1D, начало, опорный-1, б, arr_2D);
	  ИначеЕсли опорный+1 < конец Тогда
	    СортировкаХоара(arr_1D, опорный+1, конец, б, arr_2D);
	  КонецЕсли;
  КонецЕсли;	
КонецПроцедуры

Функция разделение(arr_1D, начало, конец, б, arr_2D)
  Перем опорный, тек, т;
  опорный = начало;
  тек = конец;
  Пока опорный <> тек Цикл
	Если ИсклИЛИ(arr_1D[опорный] > arr_1D[тек], опорный > тек) Тогда
	  swap(arr_1D[опорный], arr_1D[тек]);
	  
	  Если arr_2D <> Неопределено Тогда
    	swap(arr_2D[опорный], arr_2D[тек]);
		  swap(б[опорный], б[тек]);
	  КонецЕсли;
	
	  т = опорный;
	  опорный = тек;
	  Если т < тек Тогда
		  тек = т+1;
	  Иначе
		  тек = т-1;
	  КонецЕсли;
    Иначе
	  Если опорный < тек Тогда
		  тек = тек - 1;
	  Иначе
		  тек = тек + 1;
	  КонецЕсли;
	КонецЕсли;
  КонецЦикла;
Возврат опорный;
КонецФункции

Функция ИсклИЛИ(арг1, арг2)
  Перем выражение;
  выражение = (арг1 и (НЕ арг2)) или ((НЕ арг1) и арг2);  //по свойству (A->B) /\ (B->A)
  Возврат выражение;
КонецФункции

Процедура swap(a, b)
  tmp = Новый Массив;   //на вход обязательно подаются либо числа, либо массивы
  Если (ТипЗнч(a) = Тип("Число")) и (ТипЗнч(b) = Тип("Число")) Тогда
	b = b + a;
	a = b - a;
	b = b - a;
  Иначе
	tmp = a;
	a = b;
	b = tmp;
  КонецЕсли;
КонецПроцедуры

Функция QRразложение(a, N, СобствЧисла)
  Перем колИтер, eps;
  rezerva = Новый Массив(N, N);
  reserve = Новый Массив(N, N);
  T = Новый Массив(N, N);
  Q = Новый Массив(N, N);
  
  колИтер = 0;
  eps = истина;
  Пока eps и колИтер < 10001 Цикл //колИтер - если QR-алгоритм не будет сходиться
	 равноМатр(N, rezerva, a);
	 QRротация(N, a, reserve, T, Q);
	 умножМатр(N, reserve, Q, a);
	 eps = НЕ метрика(N, a);
	 колИтер = колИтер + 1;
  КонецЦикла;
 
  Если колИтер = 10000 Тогда
	Возврат ложь;
  Иначе
    СобствЧисла.Максимальное = a[0][0];
	СобствЧисла.Минимальное = a[0][0];
    Для i=1 по N-1 Цикл
	    Если СобствЧисла.Максимальное < a[i][i] Тогда
		    СобствЧисла.Максимальное = a[i][i];
	    КонецЕсли;
	
	    Если СобствЧисла.Минимальное > a[i][i] Тогда
	      СобствЧисла.Минимальное = a[i][i];
	    КонецЕсли;
    КонецЦикла;
    Возврат Истина;
  КонецЕсли;
КонецФункции

Процедура QRротация(n, a, reserve, T, Q)
   Перем i, j, r, m, k1, k2, sin, cos;
   Для i=0 по n-1 Цикл
	   Для j=0 по n-1 Цикл
	   reserve[i][j] = a[i][j];
	    Если i = j Тогда
		    T[i][i] = 1;
		    Q[i][i] = 1;
	    Иначе
		    T[i][j] = 0;
		    Q[i][j] = 0;
	    КонецЕсли;
     КонецЦикла;  
   КонецЦикла;
   
   Для i=0 по n-2 Цикл
	 Для j=i+1 по n-1 Цикл
	   k1 = a[i][i];
	   k2 = a[j][i];
	   Если k1=0 и k2=0 Тогда
		   sin = 0;
		   cos = 1;
	   Иначе
	     sin = (-1)*k2/sqrt(k1*k1 + k2*k2);
	     cos = k1/sqrt(k1*k1 + k2*k2);
	   КонецЕсли;
	   T[j][i] = sin;
	   T[i][i] = cos;
	   T[i][j] = (-1)*sin;
	   T[j][j] = cos;
	   умножениеСлева(n, T, a);
	   умножениеСлева(n, T, Q);
	   Для r=0 по N-1 Цикл
	     Для m=0 по N-1 Цикл
	       Если r = m Тогда
		       T[r][r] = 1;
	       Иначе
		       T[r][m] = 0;
	       КонецЕсли;
        КонецЦикла;  
      КонецЦикла;
   КонецЦикла;  
   КонецЦикла;
   умножениеСлева(n, Q, reserve);
   транспонирование(n, Q);
КонецПроцедуры

Функция ПроверкаСимм(n, a)
  Перем i, j, flag;
  flag = истина;
  Для i=0 по n-2 Цикл
	Для j=i+1 по n-1 Цикл
	  Если a[i][j] <> a[j][i] Тогда
		  flag = ложь;	
	  КонецЕсли;	
  КонецЦикла;  
  КонецЦикла;
Возврат flag;
КонецФункции

Процедура транспонирование(n, a)
