&НаКлиенте
Процедура ВыполнитьКоманду(Команда)
    пр_СоздатьДекорацию();
КонецПроцедуры

&НаСервере
Процедура пр_СоздатьДекорацию()
	омега = Новый Массив;
	Попытка
	х = Число(Погрешность);	  
	Если Порядок = 0 или Порядок = 1 или Метод = "" или х > 1 или х <= 0 Тогда
		Если х > 1 Тогда
			Сообщить("Погрешность больше единицы.");
		ИначеЕсли х <= 0 Тогда
		    Сообщить("Погрешность отрицательна.");
		Иначе
			Сообщить("Некоторые поля не заполнены или заполнены неверно.");
		КонецЕсли;
	Иначе
	 ЭтаФорма.Элементы.ВыполнитьКоманду.Доступность = Ложь;	//блокировка непонятного для пользователя сообщения о 
	 //недопустимости параметров (возникает при повторном нажатии на кнопку "Выполнить команду")
	 ГлавГруппа = ЭтаФорма.Элементы.Вставить("ГлавнаяГруппа", Тип("ГруппаФормы"), ЭтаФорма);
	 ГлавГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	 ГлавГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	 ГлавГруппа.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
	 ГлавГруппа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	 //Каждую Группуi помещаем в ГруппуФормы (вертикально!)
	 
	 //Создаем Группы
	 СПГрупп = Новый Массив;
     Для м=1 по Порядок Цикл
       НоваяГруппа = ЭтаФорма.Элементы.Вставить("Группа" + Формат(м, "ЧГ="), Тип("ГруппаФормы"), ГлавГруппа);
       НоваяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
       СПГрупп.Добавить(НоваяГруппа);
	   СПГрупп[м-1].Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	 КонецЦикла;	 
	 
   //Добавляем реквизит
   нРеквизиты = Новый Массив;
	 Для м=1 по Порядок Цикл
	   Для т=1 по Порядок+1 Цикл
			 Если т <= Порядок-1 Тогда
               Реквизит = Новый РеквизитФормы("Реквизит" + Формат(м, "ЧГ=") + Формат(т, "ЧГ="), Новый ОписаниеТипов("Число"), , "X" + ФормСтрока(т) + Символы.НПП + "+" + Символы.НПП, Ложь);
		   ИначеЕсли т = Порядок Тогда
			   Реквизит = Новый РеквизитФормы("Реквизит" + Формат(м, "ЧГ=") + Формат(т, "ЧГ="), Новый ОписаниеТипов("Число"), , "X" + ФормСтрока(т) + Символы.НПП + "=" + Символы.НПП, Ложь);
		   Иначе
			   Реквизит = Новый РеквизитФормы("Реквизит" + Формат(м, "ЧГ=") + Формат(т, "ЧГ="), Новый ОписаниеТипов("Число"), , "  ", Ложь);
			 КонецЕсли;
      нРеквизиты.Добавить(Реквизит);
	   КонецЦикла;
	 КонецЦикла;
   ИзменитьРеквизиты(нРеквизиты);
	 	 
	 //Добавляем поля ввода
	 Для м=1 по Порядок Цикл
	   Для т=1 по Порядок+1 Цикл
         Элемент = ЭтаФорма.Элементы.Добавить("Поле" + Формат(м, "ЧГ=") + Формат(т, "ЧГ="), Тип("ПолеФормы"), СПГрупп[м-1]);
         Элемент.Вид = ВидПоляФормы.ПолеВвода;
         Элемент.ПутьКДанным = "Реквизит" + Формат(м, "ЧГ=") + Формат(т, "ЧГ=");
         Элемент.АвтоМаксимальнаяШирина = Ложь;
         Элемент.МаксимальнаяШирина = 10;
         Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
         Элемент.ШрифтЗаголовка = Новый Шрифт("Gabriola",,, Истина);
       КонецЦикла;
   КонецЦикла;
   
	 ГлавГруппа2 = ЭтаФорма.Элементы.Вставить("ГлавнаяГруппа2", Тип("ГруппаФормы"), ЭтаФорма);
	 ГлавГруппа2.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	 ГлавГруппа2.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	 ГлавГруппа2.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
	 
	 Элемент = ЭтаФорма.Элементы.Добавить("Надпись1", Тип("ДекорацияФормы"), ГлавГруппа2);
	 Элемент.Вид = ВидДекорацииФормы.Надпись;
	 Элемент.Шрифт = Новый Шрифт("Gabriola", 20);
	 Элемент.Заголовок = "Задайте начальное приближение:";
	 
   ВложГруппа2 = ЭтаФорма.Элементы.Вставить("ГруппаПриближение", Тип("ГруппаФормы"), ГлавГруппа2);
	 ВложГруппа2.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	 ВложГруппа2.ОтображатьЗаголовок = Ложь;
	 ВложГруппа2.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Одинарный;
	 ВложГруппа2.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
	 ВложГруппа2.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	 
	 
	 начПриближение = Новый Массив;
	 Для т=1 по Порядок Цикл
	     Реквизит = Новый РеквизитФормы("Приближение" + Формат(т, "ЧГ="), Новый ОписаниеТипов("Число"), , "X" + ФормСтрока(т), Ложь);
	     начПриближение.Добавить(Реквизит);
	 КонецЦикла;
	 ИзменитьРеквизиты(начПриближение);
	 
	 Для т=1 по Порядок Цикл
	     Элемент = ЭтаФорма.Элементы.Добавить("ПолеПрибл" + Формат(т, "ЧГ="), Тип("ПолеФормы"), ВложГруппа2);
	     Элемент.Вид = ВидПоляФормы.ПолеВвода;
	     Элемент.ПутьКДанным = "Приближение" + Формат(т, "ЧГ=");
	     Элемент.АвтоМаксимальнаяШирина = Ложь;
	     Элемент.МаксимальнаяШирина = 7;
	     Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	     Элемент.ШрифтЗаголовка = Новый Шрифт("Gabriola",,, Истина);		 
	 КонецЦикла;
	 
	 Если Метод = "Релаксации" Тогда
	     ГлавГруппа3 = ЭтаФорма.Элементы.Вставить("ГлавнаяГруппа3", Тип("ГруппаФормы"), ЭтаФорма);
	     ГлавГруппа3.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		   ГлавГруппа3.ОтображатьЗаголовок = Ложь;
	     ГлавГруппа3.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	     ГлавГруппа3.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
		 
		   Элемент = ЭтаФорма.Элементы.Добавить("Надпись2", Тип("ДекорацияФормы"), ГлавГруппа3);
	     Элемент.Вид = ВидДекорацииФормы.Надпись;
	     Элемент.Шрифт = Новый Шрифт("Gabriola", 20);
	     Элемент.Заголовок = "Задайте параметр релаксации:";
		 
		   РеквизитРел = Новый РеквизитФормы("Омега", Новый ОписаниеТипов("Число"), , Символ(937), Ложь);
		   омега.Добавить(РеквизитРел);
       ИзменитьРеквизиты(омега);
		 
		   Элемент = ЭтаФорма.Элементы.Добавить("ПолеРелаксац", Тип("ПолеФормы"), ГлавГруппа3);
	     Элемент.Вид = ВидПоляФормы.ПолеВвода;
	     Элемент.ПутьКДанным = "Омега";
	     Элемент.АвтоМаксимальнаяШирина = Ложь;
	     Элемент.МаксимальнаяШирина = 7;
		   Элемент.МаксимальнаяВысота = 1;
	     Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	     Элемент.ШрифтЗаголовка = Новый Шрифт("Gabriola",,, Истина,,,,);
		   Элемент.МаксимальноеЗначение = 1.99999;
		   Элемент.МинимальноеЗначение = 0.00001
	 КонецЕсли;

	 //Добавляем форме команду
   Кмд = ЭтаФорма.Команды.Добавить("Команда1");
   Кмд.Действие = "Вывести";
   Кмд.Заголовок = "Решить СЛАУ";
	 
   //Добавляем саму кнопку
   Кнопка = ЭтаФорма.Элементы.Добавить("Кнопка1", Тип("КнопкаФормы"), ЭтаФорма);
   Кнопка.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
   Кнопка.ИмяКоманды = "Команда1";  
 КонецЕсли;
 Исключение
	  Cообщить("Некорректный ввод или заполнены не все поля формы. Пожалуйста, повторите попытку.");
 КонецПопытки;
КонецПроцедуры

&НаСервере
Процедура Вывести(Команда)
	Перем ом, колИтер, строкиИкс, eps, преобрУспех, колЗнаковEps, тау, max;
	х_пред = Новый Массив(Порядок);
	temp = Новый Массив(Порядок);
	maxrow = Новый Массив(Порядок);
	maxind = Новый Массив(Порядок);
	maxind_rez = Новый Массив(Порядок);
	резервБ = Новый Массив(Порядок);
	б = Новый Массив(Порядок);
	икс = Новый Массив(Порядок);
	невязка = Новый Массив(Порядок);
	Прибл = Новый Массив(Порядок);
	СобЧисла = Новый Структура("Минимальное,Максимальное",0,0);
	колИтер = 0;
	
	//Метод Зейделя
	х_пред_zeid = Новый Массив(Порядок);
	
	//Метод Релаксации
	х_пред_rel = Новый Массив(Порядок);
	
	матр = Новый Массив(Порядок, Порядок);
	резервМатр = Новый Массив(Порядок, Порядок);
	матрТ = Новый Массив(Порядок, Порядок);
	матрQR = Новый Массив(Порядок, Порядок);
	матрQR2 = Новый Массив(Порядок, Порядок);
	Для м=1 по Порядок Цикл
	  Для т = 1 по Порядок Цикл
		матр[м-1][т-1] = ЭтотОбъект["Реквизит" + Формат(м, "ЧГ=") + Формат(т, "ЧГ=")];
		резервМатр[м-1][т-1] = матр[м-1][т-1];
	  КонецЦикла;
    КонецЦикла;
  
	Для м=1 по Порядок Цикл
	  б[м-1] = ЭтотОбъект["Реквизит" + Формат(м, "ЧГ=") + Формат(Порядок+1, "ЧГ=")];
	  резервБ[м-1] = б[м-1];
    КонецЦикла;
	
	Для м=1 по Порядок Цикл
	  Прибл[м-1] = ЭтотОбъект["Приближение" + Формат(м, "ЧГ=")];
	  х_пред[м-1] = Прибл[м-1];
	  х_пред_zeid[м-1] = 0; // к методу Зейделя
	  х_пред_rel[м-1] = 0; //к методу релаксации
	  temp[м-1] = 0; //к методу Якоби
	КонецЦикла;
	
	строкиИкс = "";
	
	Если Метод = "Якоби" Тогда
	 ом = 1;
    ИначеЕсли Метод = "Зейдель" Тогда
	 ом = 1;
    Иначе
	 ом = ЭтотОбъект["Омега"];
	 Если ом <= 0 или ом >= 2 Тогда
	   Сообщить("Некорректное значение параметра релаксации. Пожалуйста, повторите ввод.");
	   Возврат;
	 КонецЕсли;
    КонецЕсли;
 	
	преобрУспех = диагональ(матр, б, Порядок);
	Если НЕ преобрУспех Тогда
	  Сообщить("Освобождение главной диагонали от нулевых элементов путем перестановки строк не привело к успеху." + Символы.ПС + "Решить данную систему с помощью итерационных методов невозможно.");
	  Возврат;
    Иначе
	  Если НЕ ДиагональноеПреобладание(матр, б, maxrow, maxind, maxind_rez, Порядок) Тогда
		Если НЕ ПроверкаСимм(Порядок, матр)	Тогда
		  равноМатр(Порядок, матрТ, матр);
		  транспонирование(Порядок, матрТ);
		  умножениеСлева(Порядок, матрТ, матр);
		  умножБ(Порядок, матрТ, б); //построение положительно определенной матрицы
		КонецЕсли;
		
		Если метод = "Релаксации" Тогда
		  ом = 1;
		КонецЕсли;
		матрВ(матр, б, ом);
		
		равноМатр(Порядок, матрQR, матр);
		Если QRразложение(матрQR, Порядок, СобЧисла) Тогда
		  max = abs(матрQR[0][0]);
		  Для i=1 по матрQR.ВГраница() Цикл
			Если abs(матрQR[i][i]) > max Тогда
			  max = abs(матрQR[i][i]);	  
			КонецЕсли;
		  КонецЦикла;
		  
		  Если max >= 1 Тогда
			Если Метод <> "Якоби" Тогда
		      Сообщить("Спектр матрицы B выходит за границы единичного круга." + Символы.ПС + "Применен метод оптимального спектрального параметра для метода Якоби..." + Символы.ПС + "Метод решения СЛАУ изменен с метода " + Метод + " на метод Якоби.");
			  Метод = "Якоби";
			КонецЕсли;
            тау = окр(-1*((СобЧисла.Максимальное + СобЧисла.Минимальное)/2), 10); //оптимальное значение параметра тау
			матрВТау(матр, б, тау);
		  КонецЕсли;  
	    Иначе
		   normaM = нормаМатр(матр, Порядок);
		   тау = -1*3*normaM/4; //-(normaM + normaM/2)/2 - если собственные числа неизвестны, то за тау принимают число, большее любой из легко вычисляемых норм матрицы (неоптимальное значение параметра тау)
		   МатрВТау(матр, б, тау);
	    КонецЕсли;
	    равноМатр(Порядок, матрQR2, матр);
		Если QRразложение(матрQR2, Порядок, СобЧисла) Тогда
		  max = abs(матрQR2[0][0]);
		  Для i=1 по матрQR2.ВГраница() Цикл
		    Если abs(матрQR2[i][i]) > max Тогда
		      max = abs(матрQR2[i][i]);	  
		    КонецЕсли;
		  КонецЦикла;
		  Если abs(max-1) <= 0.015 или max >= 1 Тогда //при max = 0.985... замечено отсутствие сходимости итерационного процесса
		    Сообщить("Спектральный радиус преобразованной матрицы больше либо почти равен единице." + Символы.ПС + "Необходимое и достаточное условие сходимости итерационного процесса не выполнено.");
		    Возврат;
		  КонецЕсли;
	    Иначе
		  Сообщить("QR-алгоритм расходится. Оценка необходимого и достаточного условия сходимости итерационного процесса невозможна." + Символы.ПС + "Максимальное количество итераций установлено равным 10 000.");
	    КонецЕсли; //спектральный радиус преобразованной матрицы
	  Иначе
		матрВ(матр, б, ом);
	  КонецЕсли;
	КонецЕсли;

	eps = Число(Погрешность);
	колЗнаковEps = СтрДлина(Формат(eps-Цел(eps),"ЧН=0."))-2;
	normaM = нормаМатр(матр, Порядок);
	eps = abs(((1-normaM)/normaM) * eps);

	Если Метод = "Якоби" Тогда
	  умнож(матр, х_пред, temp, Порядок);
	  минусМатр(икс, temp, б, Порядок);
	  Пока нормаВектора(х_пред, икс, Порядок) > eps и колИтер < 1000 Цикл
	    равно(х_пред, икс, Порядок);
	    умнож(матр, х_пред, temp, Порядок);
	    минусМатр(икс, temp, б, Порядок);
	    колИтер = колИтер + 1;
	  КонецЦикла;
	
	  Если колИтер = 1000 Тогда //если собственные числа не будут найдены, а итерационный процесс расходится
	    Сообщить("Итерационный процесс расходится.");
	  Иначе
		  строкиИкс = "Решение СЛАУ методом Якоби: " + Символы.ПС;
	    Для i=0 по Порядок-1 Цикл
          строкиИкс = строкиИкс + "Х" + ФормСтрока(i+1) + " = " + Формат(икс[i], "ЧДЦ=" + Строка(колЗнаковEps) + "; ЧН=") + Символы.ПС;
	    КонецЦикла;
		
		  строкиИкс = строкиИкс + Символы.ПС;
	    умнож(резервМатр, икс, temp, Порядок);
	    строкиИкс = строкиИкс + "Вектор невязки:" + Символы.ПС;
		
		Для i=0 по Порядок-1 Цикл
		  невязка[i] = abs(резервБ[i] - temp[i]);
          строкиИкс = строкиИкс + Символ(949) + ФормСтрока(i+1) + " = " + Строка(окр(невязка[i], 10)) + Символы.ПС;
	    КонецЦикла;
		
		  строкиИкс = строкиИкс + Символы.ПС + "Количество итераций: " + строка(колИтер) + Символы.ПС;
	    Сообщить(строкиИкс);
      КонецЕсли;
    ИначеЕсли Метод = "Зейдель" Тогда
	    след_итер_zeid_and_rel(х_пред_zeid, х_пред, Порядок, матр, б, ом);
	    Пока нормаВектора(х_пред_zeid, х_пред, Порядок) > eps и колИтер < 10000 Цикл
		    равно(х_пред_zeid, х_пред, Порядок);
	      след_итер_zeid_and_rel(х_пред_zeid, х_пред, Порядок, матр, б, ом);
	      колИтер = колИтер + 1;
	    КонецЦикла;
	
	  Если колИтер = 10000 Тогда
	    Сообщить("Итерационный процесс расходится.");
	  Иначе
		строкиИкс = "Решение СЛАУ методом Зейделя: " + Символы.ПС;
	    Для i=0 по Порядок-1 Цикл
