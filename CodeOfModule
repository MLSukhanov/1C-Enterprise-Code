  КонецЦикла;
КонецПроцедуры

Процедура умножениеСлева(n, a, b)
  Перем i, j, k;
  result = Новый Массив(n, n);
  Для i=0 по n-1 Цикл
	Для j=0 по n-1 Цикл
	  result[i][j] = 0;	  
	  Для k=0 по n-1 Цикл
		  result[i][j] = result[i][j] + Окр(a[i][k], 10) * Окр(b[k][j], 10);
    КонецЦикла;  
  КонецЦикла;  
  КонецЦикла;

  Для i=0 по n-1 Цикл
	Для j=0 по n-1 Цикл
      b[i][j] = result[i][j];
  КонецЦикла;  
  КонецЦикла;  
КонецПроцедуры

Функция метрика(n, a)
  Перем flag, sum;
  flag = истина;
  sum = 0;
  Для m=0 по N-2 Цикл
	Для l=m+1 по N-1 Цикл
	  sum = sum + a[l][m]*a[l][m];	
  КонецЦикла;
  
  sum = sqrt(sum);
	 Если sum < 0.000001 Тогда
	   flag = flag И истина;
   Иначе
	   flag = flag И ложь;
   КонецЕсли;
  sum = 0;
  КонецЦикла;
Возврат flag;
КонецФункции

Процедура равноМатр(N, rezerva, a)
  Перем i, j;
  Для i=0 по N-1 Цикл
	Для j=0 по N-1 Цикл
	  rezerva[i][j] = a[i][j];	  
  КонецЦикла;  
  КонецЦикла;  
КонецПроцедуры

Функция диагональ(матр, б, N)
  Перем ряд, find, flag, flagline, m, l, p; //убираем нули с главной диагонали основной матрицы СЛАУ
  Для i=0 по N-1 Цикл
	flagline = ложь;
    Для j=0 по N-1 Цикл
	  Если матр[i][j] <> 0 Тогда
		  flagline = flagline ИЛИ истина;
	  Иначе
		  flagline = flagline ИЛИ ложь;
	  КонецЕсли;		
    КонецЦикла;
  
	Если НЕ flagline Тогда
	  Возврат ложь;
	КонецЕсли;
  КонецЦикла; //одна или несколько нулевых строк
  
  Для i=0 по N-1 Цикл
    flag = ложь;
	  Если матр[i][i] = 0 Тогда //i - текущая (первая) строка для перестановки
	   Для ряд=0 по N-1 Цикл
		 Если матр[ряд][i] <> 0 и матр[i][ряд] <> 0 Тогда
		   find = ряд;
		   flag = истина;
		   Прервать; //поиск второй строки для перестановки
		 КонецЕсли;
	   КонецЦикла;
	  
	   Если ряд = N и flag = ложь Тогда //если перестановка строк невозможна, то предпринимаем пытытку их сложить (тождественное преобразование СЛАУ)
		  Для m=0 по N-1 Цикл
		    Если матр[m][m] = 0 Тогда
			   Для l=0 по N-1 Цикл
			    Если матр[l][m] <> 0 Тогда
				   б[m] = б[m] + б[l];	
			 	   Для p=0 по N-1 Цикл
			 	    матр[m][p] = матр[m][p] + матр[l][p];
			     КонецЦикла;
			     Прервать;
			    КонецЕсли;	
		     КонецЦикла;
			
			   Если l = N Тогда
			     Возврат flag;
			   КонецЕсли;
		    КонецЕсли;
	     КонецЦикла;
	   Иначе
	     Для j=0 по N-1 Цикл
		     swap(матр[i][j], матр[find][j]);
	     КонецЦикла;
	     swap(б[i], б[find]);
	    КонецЕсли;
	   КонецЕсли;
  КонецЦикла;

Возврат истина;
КонецФункции

Процедура след_итер_zeid_and_rel(x_pr, x_next, N, a, b, om)
  Перем i, j, s1, s2;
  Для i=0 по N-1 Цикл
    s1 = 0;
	  s2 = 0;
	  Для j=0 по i-1 Цикл
	    s1 = s1 + a[i][j]*x_next[j];
	  КонецЦикла;
	
	  Для j=i+1 по N-1 Цикл
	    s2 = s2 + a[i][j]*x_pr[j];
    КонецЦикла;
    x_next[i] = s1 + s2 + b[i] - x_pr[i]*(om-1);
  КонецЦикла; 
КонецПроцедуры

