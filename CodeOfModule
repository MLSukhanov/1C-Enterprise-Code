Функция ДиагональноеПреобладание(a, б, maxrow, maxind, maxind_rez, N)
  МаксПоСтрокам(a, maxrow, maxind, maxind_rez, N);    //адаптированная под 1С функция проверки диагонального преобладания из языка MatLab
  Если CheckArr(a, maxrow, maxind, N) и isequal(maxind, N) Тогда
	  СортировкаХоара(maxind_rez, 0, maxind_rez.ВГраница(), б, a);
	  Возврат истина;
  Иначе
	  Возврат ложь;
  КонецЕсли;
КонецФункции

Процедура МаксПоСтрокам(a, maxrow, maxind, maxind_rez, N)
  Перем max, maxi;
  Для i=0 по N-1 Цикл
	  max = abs(a[i][0]);
	  maxi = 0;
	  Для k=1 по N-1 Цикл
	    Если abs(a[i][k]) > max Тогда
		    max = abs(a[i][k]);
		    maxi = k;
	    КонецЕсли;
    КонецЦикла;
    maxrow[i] = max;
	  maxind[i] = maxi;
	  maxind_rez[i] = maxi;
  КонецЦикла;
КонецПроцедуры

Функция CheckArr(a, maxrow, maxind, N)
  Перем flag, sum;
  flag = true;
  sum = 0;
  Для i=0 по N-1 Цикл
	  Для j=0 по N-1 Цикл
	    sum = sum + abs(a[i][j]);  
    КонецЦикла;
  
	Если maxrow[i] > (sum - maxrow[i]) Тогда
	  flag = flag и истина;
  Иначе
	  flag = ложь;
	  Прервать;
    КонецЕсли;
    sum = 0;
  КонецЦикла;
Возврат flag;
КонецФункции

