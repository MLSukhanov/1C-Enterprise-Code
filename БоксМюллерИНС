Функция ГСЧНРаспр(мю=0, сигма=1)
	pi = 3.1415926535897932;  // преобразование Бокса-Мюллера независимых случайных чисел U1 и U2 из равномерного распределения в числа из стандартного нормального распределения
	U1 = ПолучитьСлучайноеЧисло(); // среднее 0, дисперсия 1 
	U2 = ПолучитьСлучайноеЧисло(); // нормальное распределение требуется для начальной инициализации весов ИНС 
	Z0 = sqrt(-2*log(U1))*cos(2*pi*U2);
	Z0 = Окр(Z0,10)*сигма+мю;
	Возврат Z0;
