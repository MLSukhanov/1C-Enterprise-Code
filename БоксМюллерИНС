Функция Двм(а, б)
	М = а.Количество();
	Н = б[0].Количество();
	К = б.Количество();
	
	с = Новый Массив(М, Н);
	Для i=0 по М-1 Цикл
		стмп = с[i];
		Для t=0 по Н-1 Цикл
			стмп[t] = 0;
		КонецЦикла;
		
		Для k=0 по К-1 Цикл
			ч = а[i][k];
			бтмп = б[k];
			Для j=0 по Н-1 Цикл
				стмп[j] = стмп[j] +  ч * бтмп[j];
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
Возврат с;
КонецФункции

