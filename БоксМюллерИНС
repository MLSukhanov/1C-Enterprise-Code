Функция умнож(м, в)
   Перем i, j;	
   т = Новый Массив(м.Количество());
   Для i=0 по м.ВГраница() Цикл
	 т[i] = 0;  
	 Для j=0 по м[0].ВГраница() Цикл
	   т[i] = т[i] + м[i][j]*в[j];
     КонецЦикла;  
   КонецЦикла;
 
   Возврат т; 
КонецФункции

Функция fmin(r, p)
   Если ТипЗнч(r) = Тип("Массив") Тогда
     т = Новый Массив(r.ВГраница()+1);
     Для н = 0 по т.ВГраница() Цикл
	  Если r[н] >= p Тогда
		т[н] = p;   
	  Иначе
		т[н] = r[н];
	  КонецЕсли;
     КонецЦикла;
     Возврат т;
 	Иначе
	 п = ?(r >= p, p, r);
	 Возврат п;
	КонецЕсли;
КонецФункции

